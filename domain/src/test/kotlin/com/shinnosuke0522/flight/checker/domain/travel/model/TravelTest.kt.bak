package com.shinnosuke0522.flight.checker.domain.travel.model

import arrow.core.nonEmptyListOf
import com.shinnosuke0522.flight.checker.domain.base.event.DomainEventId
import com.shinnosuke0522.flight.checker.domain.base.event.DomainEventMeta
import com.shinnosuke0522.flight.checker.domain.shared.primitive.FlightIdentity
import com.shinnosuke0522.flight.checker.domain.travel.error.FlightDateOutsideScheduleError
import com.shinnosuke0522.flight.checker.domain.travel.error.TravelAlreadyCanceled
import com.shinnosuke0522.flight.checker.domain.travel.error.TravelAlreadyCompleted
import com.shinnosuke0522.flight.checker.domain.travel.error.TravelAlreadyStartedError
import com.shinnosuke0522.flight.checker.domain.travel.error.TravelNotStartedError
import com.shinnosuke0522.flight.checker.domain.travel.event.FlightSegmentAdded
import com.shinnosuke0522.flight.checker.domain.travel.event.TravelEvent
import com.shinnosuke0522.flight.checker.domain.travel.event.TravelPlanned
import com.shinnosuke0522.flight.checker.domain.travel.service.TravelFlightService
import com.shinnosuke0522.flight.checker.domain.travel.service.TravelLifecycleService
import io.kotest.assertions.arrow.core.shouldBeLeft
import io.kotest.assertions.arrow.core.shouldBeRight
import io.kotest.core.spec.style.DescribeSpec
import io.kotest.matchers.shouldBe
import io.kotest.matchers.types.shouldBeInstanceOf
import java.time.Instant
import java.time.LocalDate

class TravelTest : DescribeSpec() {
    init {
    describe("Travel aggregate state transitions and business rules") {

        context("Given: A newly planned travel (PLANNED)") {
            val travelName = TravelName.Companion("Trip").shouldBeRight()
            val schedule = RoundTripSchedule.Companion(departureDate, returnDate).shouldBeRight()
            val initialFlightIdentity = FlightIdentity.create("JL001", departureDate).shouldBeRight()
            val flights = Flights(nonEmptyListOf(FlightSegment(initialFlightIdentity)))

            val initialTravel = givenTravel(
                TravelPlanned(
                    id = DomainEventId.generate(),
                    aggregateId = TravelId.generate(),
                    sequenceNumber = 1,
                    meta = DomainEventMeta.forRootEvent { now },
                    name = travelName,
                    schedule = schedule,
                    flights = flights
                )
            )

            context("When: Adding a flight on a date outside the schedule") {
                val flightIdentity = FlightIdentity.create("JL123", LocalDate.of(2026, 5, 1)).shouldBeRight()
                val result = TravelFlightService.addFlight(initialTravel, flightIdentity, now)

                it("Then: should return a Left with FlightDateOutsideScheduleError") {
                    result shouldBeLeft FlightDateOutsideScheduleError(
                        flightIdentity.departureDate,
                        initialTravel.schedule
                    )
                }
            }

            context("When: Adding a flight on a valid date") {
                val flightIdentity = FlightIdentity.create("JL123", LocalDate.of(2026, 5, 6))
                    .shouldBeRight()
                val result = TravelFlightService.addFlight(initialTravel, flightIdentity, now)

                it("Then: should succeed and return the updated travel and event") {
                    val (updatedTravel, event) = result.shouldBeRight()
                    updatedTravel.flights.flightSegments.any { it.identity == flightIdentity } shouldBe true
                    event.shouldBeInstanceOf<FlightSegmentAdded>()
                    event.flightIdentity shouldBe flightIdentity
                }
            }

            context("When: Trying to complete a planned travel") {
                val result = TravelLifecycleService.complete(initialTravel, now)

                it("Then: should return an error because it hasn't started") {
                    result shouldBeLeft TravelNotStartedError(initialTravel.id)
                }
            }

            context("When: Starting the travel") {
                val result = TravelLifecycleService.start(initialTravel, now)

                it("Then: should succeed and transition to STARTED") {
                    val (updatedTravel, _) = result.shouldBeRight()
                    updatedTravel.status shouldBe TravelStatus.STARTED
                }
            }
        }

        context("Given: A travel with an existing flight") {
            val flightIdentity = FlightIdentity.create("JL123", departureDate).shouldBeRight()
            val travel = givenTravel(
                TravelPlanned(
                    id = DomainEventId.generate(),
                    aggregateId = TravelId.generate(),
                    sequenceNumber = 1,
                    meta = DomainEventMeta.forRootEvent { now },
                    name = TravelName.Companion("Trip").shouldBeRight(),
                    schedule = RoundTripSchedule.Companion(departureDate, returnDate).shouldBeRight(),
                    flights = Flights(nonEmptyListOf(FlightSegment(flightIdentity)))
                )
            )

            context("When: Adding a flight that is already in the travel") {
                val result = TravelFlightService.addFlight(travel, flightIdentity, now)

                it("Then: should succeed (since duplicate check is not in Service yet)") {
                    result.shouldBeRight()
                }
            }
        }

        context("Given: A travel that is already STARTED") {
            val initialFlightIdentity = FlightIdentity.create("JL001", departureDate).shouldBeRight()
            val initialTravel = givenTravel(
                TravelPlanned(
                    id = DomainEventId.generate(),
                    aggregateId = TravelId.generate(),
                    sequenceNumber = 1,
                    meta = DomainEventMeta.forRootEvent { now },
                    name = TravelName.Companion("Trip").shouldBeRight(),
                    schedule = RoundTripSchedule.Companion(departureDate, returnDate).shouldBeRight(),
                    flights = Flights(nonEmptyListOf(FlightSegment(initialFlightIdentity)))
                )
            )
            val (startedTravel, _) = TravelLifecycleService.start(initialTravel, now).shouldBeRight()

            context("When: Starting it again") {
                val result = TravelLifecycleService.start(startedTravel, now)

                it("Then: should return TravelAlreadyStartedError") {
                    result shouldBeLeft TravelAlreadyStartedError(startedTravel.id)
                }
            }

            context("When: Completing the travel") {
                val result = TravelLifecycleService.complete(startedTravel, now)

                it("Then: should succeed and transition to COMPLETED") {
                    val (updatedTravel, _) = result.shouldBeRight()
                    updatedTravel.status shouldBe TravelStatus.COMPLETED
                }
            }

            context("When: Adding a flight to a started travel") {
                val flightIdentity = FlightIdentity.create("NH123", departureDate).shouldBeRight()
                val result = TravelFlightService.addFlight(startedTravel, flightIdentity, now)

                it("Then: should still be allowed") {
                    val (updatedTravel, _) = result.shouldBeRight()
                    updatedTravel.flights.flightSegments.any { it.identity == flightIdentity } shouldBe true
                }
            }
        }

        context("Given: A travel that is already CANCELED") {
            val initialFlightIdentity = FlightIdentity.create("JL001", departureDate).shouldBeRight()
            val initialTravel = givenTravel(
                TravelPlanned(
                    id = DomainEventId.generate(),
                    aggregateId = TravelId.generate(),
                    sequenceNumber = 1,
                    meta = DomainEventMeta.forRootEvent { now },
                    name = TravelName.Companion("Trip").shouldBeRight(),
                    schedule = RoundTripSchedule.Companion(departureDate, returnDate).shouldBeRight(),
                    flights = Flights(nonEmptyListOf(FlightSegment(initialFlightIdentity)))
                )
            )
            val (canceledTravel, _) = TravelLifecycleService.cancel(initialTravel, now).shouldBeRight()

            context("When: Any lifecycle operation is attempted") {
                it("Then: should return TravelAlreadyCanceled error") {
                    TravelLifecycleService.start(canceledTravel, now) shouldBeLeft
                        TravelAlreadyCanceled(canceledTravel.id)
                    TravelLifecycleService.complete(canceledTravel, now) shouldBeLeft
                        TravelAlreadyCanceled(canceledTravel.id)
                    TravelLifecycleService.cancel(canceledTravel, now) shouldBeLeft
                        TravelAlreadyCanceled(canceledTravel.id)
                }
            }
        }

        context("Given: A travel that is already COMPLETED") {
            val initialFlightIdentity = FlightIdentity.create("JL001", departureDate).shouldBeRight()
            val initialTravel = givenTravel(
                TravelPlanned(
                    id = DomainEventId.generate(),
                    aggregateId = TravelId.generate(),
                    sequenceNumber = 1,
                    meta = DomainEventMeta.forRootEvent { now },
                    name = TravelName.Companion("Trip").shouldBeRight(),
                    schedule = RoundTripSchedule.Companion(departureDate, returnDate).shouldBeRight(),
                    flights = Flights(nonEmptyListOf(FlightSegment(initialFlightIdentity)))
                )
            )
            val (startedTravel, _) = TravelLifecycleService.start(initialTravel, now).shouldBeRight()
            val (completedTravel, _) = TravelLifecycleService.complete(startedTravel, now).shouldBeRight()

            context("When: Any lifecycle operation is attempted") {
                it("Then: should return TravelAlreadyCompleted error") {
                    TravelLifecycleService.start(completedTravel, now) shouldBeLeft
                        TravelAlreadyCompleted(completedTravel.id)
                    TravelLifecycleService.complete(completedTravel, now) shouldBeLeft
                        TravelAlreadyCompleted(completedTravel.id)
                    TravelLifecycleService.cancel(completedTravel, now) shouldBeLeft
                        TravelAlreadyCompleted(completedTravel.id)
                }
            }
        }
    }

    companion object {
        val now = Instant.now()
        val departureDate = LocalDate.of(2026, 5, 5)
        val returnDate = LocalDate.of(2026, 5, 10)
    }
}

private fun givenTravel(vararg events: TravelEvent): Travel {
    return Travel.replay(nonEmptyListOf(events[0], *events.sliceArray(1 until events.size)))
}
